# Секреты и ключи — никогда
*.key
*.pem
*_rsa
*_ed25519
*.gpg
.env
*secret*
*token*

# Мусор
*.bak
*.swp
*.tmp
.DS_Store

# Кэши/состояние
*.log
*cache*
tmux/.config/tmux/plugins/

# Wireshark
wireshark/.config/wireshark/profiles/*/preferences
wireshark/.config/wireshark/profiles/*/extcap.cfg
wireshark/.config/wireshark/profiles/*/recent

# Claude Code state — never belongs in the package (see claude/.claude/,
# only CLAUDE.md/settings.json/commands/ are ever copied in there deliberately)
claude/.claude/.credentials*
claude/.claude/sessions/
claude/.claude/projects/
claude/.claude/todos/
claude/.claude/statsig/
claude/.claude/shell-snapshots/
claude/.claude/*.log

# machine-local hypr overrides
hypr/.config/hypr/local.lua

# cava копирует дефолтные шейдеры/темы в конфиг при запуске
cava/.config/cava/shaders/
cava/.config/cava/themes/
