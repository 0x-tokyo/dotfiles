# Секреты и ключи — никогда
*.key
*.pem
*_rsa
*_ed25519
*.gpg
.env
*secret*
*token*

# Мусор
*.bak
*.swp
*.tmp
.DS_Store

# Кэши/состояние
*.log
*cache*
